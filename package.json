{
  "name": "b24-notification-aggregator",
  "version": "1.0.0",
  "description": "Bitrix24 cross-portal notification counter aggregator. Collects notification counters (chat, notify, tasks, CRM, livefeed) from multiple Bitrix24 portals on a single host portal.",
