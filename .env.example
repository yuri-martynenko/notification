# Server
PORT=3000
NODE_ENV=production

# Public URL of this app (used for OAuth callbacks and webhook URLs)
# Example: https://app-XXXXXXXX.vibecode.bitrix24.tech
APP_PUBLIC_URL=https://localhost:3000

# Host portal — the Bitrix24 portal where this app is installed
HOST_PORTAL_DOMAIN=iumiti.bitrix24.ru

# SQLite path
DB_PATH=./data/app.db

# Default polling interval (seconds). User-configurable via UI.
DEFAULT_POLL_INTERVAL_SEC=120

# Encryption key for storing tokens at rest (32 bytes hex). Generate via:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_me_with_64_hex_chars

# Optional: VibeCode API key (only for host-portal helper calls, not required for cross-portal logic)
VIBECODE_API_KEY=
